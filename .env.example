# ============================================================================
# Brella Mass Outbound — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values.

# --- Brella API Authentication ---
# Option 1: Paste the JSON from localStorage.getItem('authHeaders') in your browser
# BRELLA_AUTH_TOKEN={"access-token":"xxx","client":"xxx","uid":"xxx@email.com","token-type":"Bearer"}
#
# Option 2: Email + password login
# BRELLA_EMAIL=your@email.com
# BRELLA_PASSWORD=your-password

BRELLA_API_BASE_URL=https://api.brella.io/api
BRELLA_RATE_LIMIT_DELAY=0.5

# --- LLM Provider ---
# Options: claude, openai, template (default: template — no API key needed)
LLM_PROVIDER=template

# Claude (if LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini

# --- Campaign Defaults ---
CAMPAIGN_MESSAGE_MAX_LENGTH=500
CAMPAIGN_DRY_RUN=true
CAMPAIGN_FOOTER=📨 via github.com/Stupidoodle/brella-mass-outbound
CAMPAIGN_FOOTER_ENABLED=true

# --- Database ---
DATABASE_URL=sqlite:///brella_outbound.db

# --- Logging ---
LOG_LEVEL=INFO

# --- MCP Server ---
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765
